{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Requests QPS",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "sum(rate(devstore_http_requests_total[1m])) by (path)", "legendFormat": "{{path}}"}]
    },
    {
      "type": "timeseries",
      "title": "HTTP P95 Duration",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(devstore_http_request_duration_seconds_bucket[5m])) by (le, path))", "legendFormat": "{{path}}"}]
    },
    {
      "type": "stat",
      "title": "4xx Rate",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 8},
      "targets": [{"expr": "sum(rate(devstore_http_requests_total{status='4xx'}[5m]))"}]
    },
    {
      "type": "stat",
      "title": "5xx Rate",
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 8},
      "targets": [{"expr": "sum(rate(devstore_http_requests_total{status='5xx'}[5m]))"}]
    }
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["devstore"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timezone": "browser",
  "title": "DevStore Overview",
  "version": 1
